# ---- Server ----
PORT=4000
NODE_ENV=development

# ---- Database ----
# Local:  mongodb://127.0.0.1:27017/voof
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/voof?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/voof

# ---- Auth secrets (REQUIRED — generate long random strings) ----
# e.g. node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ---- CORS (comma-separated allowed origins) ----
# Storefront (Next.js dev) + Admin panel (static server)
CORS_ORIGINS=http://localhost:3000,http://localhost:5500

# ---- Cookies ----
# In production behind HTTPS set COOKIE_SECURE=true
COOKIE_SECURE=false

# ---- Seed admin (used by `npm run seed:admin`) ----
SEED_ADMIN_EMAIL=admin@voof.local
SEED_ADMIN_PASSWORD=ChangeMe!2026
SEED_ADMIN_NAME=Voof Admin

# ---- Optional: serve the admin panel statically from this API at /admin ----
# Leave empty to run the admin panel from its own static server instead.
ADMIN_DIR=../voof-admin
